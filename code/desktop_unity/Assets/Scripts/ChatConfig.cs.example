/// <summary>
/// API 密钥配置示例
/// 复制本文件重命名为 ChatConfig.cs，即为项目提供密钥
///
/// ⚠️ 从 v0.10 起 API Key 从环境变量读取，无需在代码中填写：
///   DEEPSEEK_API_KEY — DeepSeek API Key
///   GLM_API_KEY      — 智谱 GLM API Key
/// 设置方法：系统属性 → 环境变量 → 用户变量 → 新建
/// 设置后重启电脑或重新登录使变量生效
///
/// 此文件内容仅为编译占位，实际 Key 来自环境变量
/// </summary>
public static class ChatConfig
{
    /// <summary>DeepSeek API Key — 从环境变量 DEEPSEEK_API_KEY 读取</summary>
    public static string ApiKey => System.Environment.GetEnvironmentVariable("DEEPSEEK_API_KEY") ?? "";

    // ========== GLM (智谱) 视觉模型配置 ==========

    /// <summary>GLM API Key — 从环境变量 GLM_API_KEY 读取</summary>
    public static string GlmApiKey => System.Environment.GetEnvironmentVariable("GLM_API_KEY") ?? "";

    /// <summary>GLM API 基础地址</summary>
    public const string GlmApiBaseUrl = "https://open.bigmodel.cn/api/paas/v4";

    /// <summary>GLM 视觉模型名</summary>
    public const string GlmVisionModel = "glm-4v-flash";
}
